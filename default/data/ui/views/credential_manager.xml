<dashboard version="1.1" theme="light" script="api_connect_credentials.js" stylesheet="api_connect.css">
  <label>API Connect — Credential Manager</label>
  <description>Gestione sicura delle credenziali tramite password.conf di Splunk</description>

  <row>
    <panel>
      <html>
        <div id="ac-cred-root">

          <div class="ac-toolbar">
            <span class="ac-toolbar-title">
              <i class="icon-lock"></i> Credenziali (password.conf)
            </span>
            <div class="ac-toolbar-actions">
              <button class="btn btn-primary" id="btn-new-cred">
                <i class="icon-plus"></i> Nuova credenziale
              </button>
            </div>
          </div>

          <div class="ac-info-banner">
            <i class="icon-info-circle"></i>
            Le credenziali sono salvate cifrate in <code>password.conf</code> tramite le API native di Splunk.
            Nessun valore in chiaro viene mai scritto su disco o trasmesso al browser.
          </div>

          <!-- Credentials table -->
          <div class="ac-table-wrap">
            <table class="table table-chrome ac-cred-table" id="ac-cred-table">
              <thead>
                <tr>
                  <th>Realm</th>
                  <th>Username / Label</th>
                  <th>Tipo</th>
                  <th>App</th>
                  <th>Ultima modifica</th>
                  <th>Azioni</th>
                </tr>
              </thead>
              <tbody id="ac-cred-tbody">
                <tr>
                  <td colspan="6" class="ac-loading">
                    <div class="ac-spinner"><i class="icon-rotate-right"></i> Caricamento...</div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Create / Edit modal -->
          <div id="ac-cred-modal" class="ac-modal-overlay" style="display:none">
            <div class="ac-modal">
              <div class="ac-modal-header">
                <span class="ac-modal-title" id="cred-modal-title">Nuova credenziale</span>
              </div>
              <div class="ac-modal-body">
                <div class="control-group">
                  <label class="control-label">Tipo <span class="ac-required">*</span></label>
                  <div class="controls">
                    <select id="cred-type" class="input-xlarge">
                      <option value="bearer">Bearer Token</option>
                      <option value="basic">Basic Auth (user:password)</option>
                      <option value="api_key">API Key</option>
                      <option value="oauth2_cc">OAuth2 Client Credentials</option>
                    </select>
                  </div>
                </div>
                <div class="control-group">
                  <label class="control-label">Label / Realm <span class="ac-required">*</span></label>
                  <div class="controls">
                    <input type="text" id="cred-realm" class="input-xlarge" placeholder="es. prod_auth_api"/>
                    <span class="help-block">Identificatore univoco usato per riferirsi a questa credenziale negli input.</span>
                  </div>
                </div>
                <!-- Bearer / API Key -->
                <div id="cred-token-group">
                  <div class="control-group">
                    <label class="control-label">Username / Client ID <span class="ac-required">*</span></label>
                    <div class="controls">
                      <input type="text" id="cred-username" class="input-xlarge" placeholder=""/>
                    </div>
                  </div>
                  <div class="control-group">
                    <label class="control-label">Password / Token / Secret <span class="ac-required">*</span></label>
                    <div class="controls ac-secret-row">
                      <input type="password" id="cred-password" class="input-xlarge" placeholder=""/>
                      <button class="btn btn-default ac-btn-sm ac-btn-toggle-pw" type="button">
                        <i class="icon-eye"></i>
                      </button>
                    </div>
                    <span class="help-block">Il valore è salvato cifrato. Non verrà mai visualizzato in chiaro dopo il salvataggio.</span>
                  </div>
                </div>
                <!-- OAuth2 extra -->
                <div id="cred-oauth2-group" style="display:none">
                  <div class="control-group">
                    <label class="control-label">Token URL <span class="ac-required">*</span></label>
                    <div class="controls">
                      <input type="text" id="cred-token-url" class="input-xlarge" placeholder="https://auth.example.com/oauth/token"/>
                    </div>
                  </div>
                  <div class="control-group">
                    <label class="control-label">Scope</label>
                    <div class="controls">
                      <input type="text" id="cred-scope" class="input-xlarge" placeholder="read write"/>
                    </div>
                  </div>
                </div>
              </div>
              <div class="ac-modal-footer">
                <button class="btn btn-default" id="cred-cancel">Annulla</button>
                <button class="btn btn-primary" id="cred-save">
                  <i class="icon-check"></i> Salva
                </button>
              </div>
            </div>
          </div>

          <!-- Delete confirm modal -->
          <div id="ac-cred-delete-modal" class="ac-modal-overlay" style="display:none">
            <div class="ac-modal">
              <div class="ac-modal-header">
                <span class="ac-modal-title">Conferma eliminazione</span>
              </div>
              <div class="ac-modal-body">
                <p>Vuoi eliminare la credenziale <strong id="cred-delete-label"></strong>?</p>
                <p class="ac-modal-warn">Gli input che usano questa credenziale potrebbero smettere di funzionare.</p>
              </div>
              <div class="ac-modal-footer">
                <button class="btn btn-default" id="cred-delete-cancel">Annulla</button>
                <button class="btn btn-primary ac-btn-danger" id="cred-delete-confirm">Elimina</button>
              </div>
            </div>
          </div>

        </div>
      </html>
    </panel>
  </row>
</dashboard>
